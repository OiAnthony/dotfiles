#!/bin/sh
set -eu

runs="${1:-20}"
tmp="$(mktemp -t zsh-benchmark.XXXXXX)"
trap 'rm -f "$tmp"' EXIT

i=0
while [ "$i" -lt "$runs" ]; do
  /usr/bin/time -p env TERM=xterm-256color zsh -lic exit >/dev/null 2>>"$tmp"
  i=$((i + 1))
done

awk '
  /^real / { values[++n] = $2 }
  END {
    if (!n) exit 1
    for (i = 1; i <= n; i++)
      for (j = i + 1; j <= n; j++)
        if (values[i] > values[j]) {
          t = values[i]; values[i] = values[j]; values[j] = t
        }
    p50 = values[int((n - 1) * 0.50) + 1]
    p95 = values[int((n - 1) * 0.95) + 1]
    printf "runs=%d p50=%.3fs p95=%.3fs min=%.3fs max=%.3fs\n",
      n, p50, p95, values[1], values[n]
  }
' "$tmp"
